<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title><%= blog.title %> - Medium</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <article class="container py-5" style="max-width: 720px;">
      <div class="mb-4">
        <h1 class="page-title mb-3"><%= blog.title %></h1>
        <div class="d-flex align-items-center gap-3 mb-4">
          <img src="<%= blog.createdBy.profileImageURL %>" alt="<%= blog.createdBy.fullName %>" class="avatar-md" />
          <div>
            <p class="mb-0 fw-bold" style="font-family:Arial,sans-serif;font-size:0.95rem;"><%= blog.createdBy.fullName %></p>
            <p class="mb-0" style="font-family:Arial,sans-serif;font-size:0.85rem;color:var(--medium-gray);">
              Published on <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %>
              <span class="mx-1">·</span>
              <%= Math.ceil((blog.body || '').length / 1000) %> min read
            </p>
          </div>
        </div>
      </div>

      <% if (blog.coverImageURL) { %>
        <img src="<%= blog.coverImageURL %>" class="page-blog-cover mb-5" alt="<%= blog.title %>" />
      <% } %>

      <div class="blog-content">
        <%- blog.body.replace(/\n/g, '<br>') %>
      </div>

      <hr class="my-5" style="border-color:var(--medium-border);" />

      <section>
        <h5 class="mb-4" style="font-family:Arial,sans-serif;font-weight:700;font-size:1.1rem;">
          <i class="fa-regular fa-comment me-2"></i>Comments (<%= comments.length %>)
        </h5>

        <% if (typeof user !== 'undefined' && user) { %>
          <form action="/blog/comment/<%= blog._id %>" method="POST" class="mb-4">
            <div class="d-flex gap-3">
              <img src="<%= user.profileImageURL %>" alt="" class="avatar-md mt-1" />
              <div class="flex-grow-1">
                <textarea class="form-control mb-2" name="content" rows="2" placeholder="What are your thoughts?" required style="border:1px solid var(--medium-border);border-radius:4px;font-family:Arial,sans-serif;font-size:0.95rem;"></textarea>
                <button type="submit" class="btn btn-medium btn-sm">Submit</button>
              </div>
            </div>
          </form>
        <% } else { %>
          <div class="alert alert-light p-4 mb-4 text-center" style="border:1px solid var(--medium-border);border-radius:8px;font-family:Arial,sans-serif;">
            <a href="/user/signin" style="color:var(--medium-green);font-weight:600;">Sign in</a> to leave a comment.
          </div>
        <% } %>

        <% if (comments.length === 0) { %>
          <div class="text-center py-5" style="color:var(--medium-gray);font-family:Arial,sans-serif;">
            <i class="fa-regular fa-message mb-2" style="font-size:1.5rem;"></i>
            <p class="mb-0">No comments yet. Be the first to share your thoughts!</p>
          </div>
        <% } else { %>
          <% comments.forEach(comment => { %>
            <div class="comment-item d-flex gap-3">
              <img src="<%= comment.createdBy.profileImageURL %>" alt="<%= comment.createdBy.fullName %>" class="avatar-sm mt-1" />
              <div class="flex-grow-1">
                <p class="mb-1 fw-bold" style="font-family:Arial,sans-serif;font-size:0.85rem;"><%= comment.createdBy.fullName %></p>
                <p class="comment-text mb-1"><%= comment.content %></p>
                <small style="color:var(--medium-gray);font-family:Arial,sans-serif;font-size:0.75rem;">
                  <%= new Date(comment.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                </small>
              </div>
            </div>
          <% }) %>
        <% } %>
      </section>
    </article>

    <%- include('./partials/script') %>
  </body>
</html>
