<!DOCTYPE html>
<html lang="en">
  <head>
    <%- include('./partials/head') %>
    <title>Medium - Where good ideas find you</title>
  </head>
  <body>
    <%- include('./partials/nav') %>

    <section class="hero-section">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-7">
            <h1 class="hero-title">Stay curious.</h1>
            <p class="hero-sub mt-3 mb-4">Discover stories, thinking, and expertise from writers on any topic that matters to you.</p>
            <% if (typeof user === 'undefined' || !user) { %>
              <a href="/user/signup" class="btn btn-medium btn-lg px-4 py-2" style="font-size:1.1rem;">Start Reading</a>
            <% } else { %>
              <a href="/blog/add-new" class="btn btn-medium btn-lg px-4 py-2" style="font-size:1.1rem;"><i class="fa-regular fa-pen-to-square me-2"></i>Write your story</a>
            <% } %>
          </div>
          <div class="col-lg-5 d-none d-lg-block text-end">
            <i class="fa-solid fa-feather-pointed" style="font-size:8rem;color:var(--medium-green);opacity:0.15;"></i>
          </div>
        </div>
      </div>
    </section>

    <div class="container py-5">
      <p class="section-title"><i class="fa-solid fa-arrow-trend-up me-2"></i>Trending on Medium</p>
      <% if (blogs.length === 0) { %>
        <div class="empty-state">
          <i class="fa-regular fa-newspaper"></i>
          <h4>No stories yet</h4>
          <p style="font-family:Arial,sans-serif;">Be the first to share your thoughts with the world.</p>
          <a href="/blog/add-new" class="btn btn-medium">Create your first post</a>
        </div>
      <% } else { %>
        <div class="row g-4">
          <% blogs.forEach((blog, index) => { %>
            <div class="col-md-6 col-lg-4">
              <div class="blog-card card" onclick="window.location='/blog/<%= blog._id %>'">
                <% if (blog.coverImageURL) { %>
                  <img src="<%= blog.coverImageURL %>" class="card-img-top" alt="<%= blog.title %>" />
                <% } else { %>
                  <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height:200px;">
                    <i class="fa-regular fa-image" style="font-size:2.5rem;color:#d0d0d0;"></i>
                  </div>
                <% } %>
                <div class="card-body px-0">
                  <div class="author-row mb-2">
                    <% if (blog.createdBy) { %>
                      <img src="<%= blog.createdBy.profileImageURL %>" alt="" class="avatar-sm me-1" />
                      <strong><%= blog.createdBy.fullName %></strong>
                    <% } else { %>
                      <strong>Anonymous</strong>
                    <% } %>
                    <span class="mx-1">·</span>
                    <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  </div>
                  <h5 class="card-title"><%= blog.title %></h5>
                  <p class="card-text"><%= blog.body ? blog.body.substring(0, 200) : '' %></p>
                  <span class="badge" style="background:var(--medium-light);color:var(--medium-gray);font-family:Arial,sans-serif;font-weight:400;font-size:0.8rem;">
                    <%= Math.ceil((blog.body || '').length / 1000) %> min read
                  </span>
                  <div class="mt-2">
                    <a href="/blog/<%= blog._id %>" class="btn btn-sm btn-medium-outline" style="font-size:0.8rem;">Read more <i class="fa-solid fa-arrow-right ms-1"></i></a>
                  </div>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <%- include('./partials/script') %>
  </body>
</html>
